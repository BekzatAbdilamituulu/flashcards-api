# Production / shared defaults
APP_ENV=production
DEBUG=false
DATABASE_URL=postgresql://postgres:postgres@db:5432/deeplex
SECRET_KEY=replace-with-a-long-random-production-secret-key-32chars-min
REFRESH_SECRET_KEY=replace-with-a-different-long-random-production-refresh-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
BACKEND_CORS_ORIGINS=https://your-frontend-domain.com
ALLOWED_HOSTS=your-backend-domain.com
RUN_MIGRATIONS_ON_START=1
MYMEMORY_DE_EMAIL=you@example.com
